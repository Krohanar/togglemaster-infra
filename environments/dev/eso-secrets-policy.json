{
  "Version": "2012-10-17",
  "Statement": [
    {
      "Sid": "ReadAppSecrets",
      "Effect": "Allow",
      "Action": [
        "secretsmanager:GetSecretValue",
        "secretsmanager:DescribeSecret"
      ],
      "Resource": [
        "arn:aws:secretsmanager:us-east-1:106978078844:secret:togglemaster/dev/auth-service*",
        "arn:aws:secretsmanager:us-east-1:106978078844:secret:togglemaster/dev/flag-service*",
        "arn:aws:secretsmanager:us-east-1:106978078844:secret:togglemaster/dev/targeting-service*",
        "arn:aws:secretsmanager:us-east-1:106978078844:secret:togglemaster/dev/evaluation-service*",
        "arn:aws:secretsmanager:us-east-1:106978078844:secret:togglemaster/dev/analytics-service*"
      ]
    }
  ]
}